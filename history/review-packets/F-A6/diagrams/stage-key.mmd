flowchart LR
  stage["StageId"] --> canon["canonical length-prefixed bytes"]
  local["ComponentDigestSet (BTreeMap)"] --> canon
  global["global Hash256"] --> canon
  flags["FeatureFlag set (BTreeSet)"] --> canon
