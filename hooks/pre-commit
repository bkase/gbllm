#!/usr/bin/env bash
# gbllm pre-commit hook
# Fast self-cert: format + clippy + low-latency lib/bin tests.
# The full feature-combo matrix (gbf-train and gbf-test qat / qat-ablation,
# gbf-experiments phase-a / ablation, gbf-cli falsify, doctests, and broad
# integration/evidence sweeps) runs in CI or targeted review scripts, not here.
set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACMR || true)

gbf_test_qat_fast_targets=(
    --lib
    --test architecture
    --test export_determinism
    --test loss_tests
    --test model_tests
    --test oracle_agreement
    --test phase_tests
    --test qat_tests
    --test ternary_tests
)

# Stage 1: formatting (instant)
if ! cargo fmt --check --all; then
    echo "pre-commit: cargo fmt failed. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Stage 2: QAT feature mutex — only when gbf-train sources/manifest staged.
if grep -qE '^gbf-train/(src/|Cargo\.toml$)' <<<"$staged"; then
    qat_mutex_output=""
    if qat_mutex_output=$(cargo build -p gbf-train --features qat,qat-ablation 2>&1); then
        echo "pre-commit: expected qat+qat-ablation build to fail, but it succeeded."
        exit 1
    fi
    if ! grep -q "qat and qat-ablation are mutually exclusive" <<<"$qat_mutex_output"; then
        echo "pre-commit: qat+qat-ablation build failed without the expected diagnostic."
        echo "$qat_mutex_output"
        exit 1
    fi
fi

# Stage 3: lint workspace main feature set.
if ! cargo clippy --workspace --exclude gbf-cli --exclude gbf-train --exclude gbf-experiments --exclude gbf-test --all-features -- -D warnings; then
    echo "pre-commit: cargo clippy found warnings. Fix them before committing."
    exit 1
fi
if ! cargo clippy -p gbf-test --no-default-features --features qat -- -D warnings; then
    echo "pre-commit: cargo clippy found warnings. Fix them before committing."
    exit 1
fi

# Stage 4: fast test gates. Keep broad integration tests and doctests out of
# pre-commit; they are high-value in CI but too slow/noisy for every commit.
if ! cargo test --workspace --exclude gbf-cli --exclude gbf-train --exclude gbf-experiments --exclude gbf-test --all-features --lib --bins; then
    echo "pre-commit: tests failed."
    exit 1
fi
if ! cargo test -p gbf-test --no-default-features --features qat "${gbf_test_qat_fast_targets[@]}"; then
    echo "pre-commit: tests failed."
    exit 1
fi

# Scripted debugger conformance is valuable but specialized. Run it when the
# staged change touches the ASM/runtime/debug surface it protects.
if grep -qE '^(gbf-asm/|gbf-runtime/|gbf-debug/|gbf-test/tests/runtime_asm_conformance\.rs|docs/review/t-a8\.8b/)' <<<"$staged"; then
    if ! cargo test -p gbf-test --no-default-features --features qat --test runtime_asm_conformance; then
        echo "pre-commit: runtime/ASM conformance tests failed."
        exit 1
    fi
fi

# Sync beads if br is available
if command -v br &>/dev/null; then
    br sync --flush-only --quiet 2>/dev/null || true
fi
